Sub copyRT(doc As NotesDocument, newDoc As NotesDocument, fieldName As String, rt As NotesRichTextItem)
        Dim s As New NotesSession
        Dim db As NotesDatabase
        Set db=s.CurrentDatabase
        
        If doc.HasItem(fieldName) Then
                Dim oldRT As NotesRichTextItem
                
                Set oldRT=doc.GetFirstItem(fieldName)
                If oldRT.Type=RICHTEXT Then
                        Call RT.AppendRTItem(oldRT)
                Else
                        Call RT.AppendText(oldRT.text)
                End If                                
        End If
        
End Sub
