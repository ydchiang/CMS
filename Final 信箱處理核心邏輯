Function getSubjectFormTypeV0(tmpSubject As String) As String
        getSubjectFormTypeV0=""
        
        '202411============
        Dim systemProfile As NotesDocument
        Dim caseTypeSettingList As Variant
        Set systemProfile = CMS_DB.GetProfileDocument("SystemProfile")
        '排除 M Type 避免與 GCMS 判斷造成衝突
        caseTypeSettingList = Evaluate(|@Trim(@Replace(@Trim(@Word(ContractResource1;":";1));"M";"")) |,systemProfile)
        '==================
        
        ' 202403 CMS & GCMS add B、M Type                 
        Dim isCMSMType As String
        isCMSMType="N"
        If Ucase$(Left(tmpSubject,1))="M" Then        ' CMS M Type 與GCMS 開頭相同
                If Ucase$(Left(tmpSubject,4))<>"MXIC" And Ucase$(Left(tmpSubject,2))<>"MX" And Ucase$(Left(tmpSubject,3))<>"MTR" Then
                        isCMSMType="Y"
                End If
        End If
        
        'Legal System Phase 19:202510 信箱判斷案號系統名稱
        Dim isSCMSMType As String
        Dim xNumberHeader As String
        Dim xitemTypeList As NotesItem
        xNumberHeader=UCase(getFlowNumberHeader(tmpSubject))
        isSCMSMType="N"                
        
        xLen=Len(xNumberHeader)
        If xLen>1 Then
                If Right(xNumberHeader,1)="S" Then
                        xNumberHeaderKey=Left(xNumberHeader,xLen-1)
                        Set xitemTypeList=systemProfile.Getfirstitem("BuTriggerTypeList")                        
                        If xitemTypeList.Contains(xNumberHeaderKey) Then
                                isSCMSMType="Y"
                        End If
                End If
        End If
        
        If tmpSubject ="T25ADE0001" Then
                isSCMSMType="Y"
        End If
        
        'If Ucase$(Left(tmpSubject,2))="SS" Or Ucase$(Right(Left(tmpSubject,5),2))="SS" Then
        If isSCMSMType="Y" Then '202510
                getSubjectFormTypeV0="SCMS"
                
        Elseif Ucase$(Left(tmpSubject,1))="S" Or Ucase$(Left(tmpSubject,1))="D" Or Ucase$(Left(tmpSubject,1))="A" Or Ucase$(Left(tmpSubject,1))="C" Or Ucase$(Left(tmpSubject,1))="G" Or Ucase$(Left(tmpSubject,2))="SG" Or Ucase$(Left(tmpSubject,5))="MXICS" Or Ucase$(Left(tmpSubject,6))="MXICSG" Or Ucase$(Left(tmpSubject,5))="MXICG" Then 
                getSubjectFormTypeV0="CMS"
                
        ' 202403 CMS add B、M Type 
        'Elseif isCMSMType="Y" Or Ucase$(Left(tmpSubject,1))="B" Then
        '202411============
        Elseif isCMSMType="Y" Or IsMember(Ucase$(Left(tmpSubject,1)),caseTypeSettingList) Then        
                getSubjectFormTypeV0="CMS"                        
                
                
        Elseif (Ucase$(Left(tmpSubject,1))="M" Or Ucase$(Left(tmpSubject,1))="I" )Then        'Gcms Case
                getSubjectFormTypeV0="GCMS"                
        End If
        
End Function
