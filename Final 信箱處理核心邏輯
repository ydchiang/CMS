Function getFlowNumberHeader(xDocNo As String) As String
        getFlowNumberHeader = ""        
        
        xLen=Len(xDocNo)
        For i=1 To xLen
                xval=Mid$(xDocNo, i, 1)
                If IsNumeric(xval) Then
                        xKeyLen=i-1
                        Exit For
                End If
        Next
        If InStr(xDocNo,"MX") > 0Then
                getFlowNumberHeader= Right( Left(xDocNo,xKeyLen) , Len(Left(xDocNo,xKeyLen))-3)
        Else
                getFlowNumberHeader=Left(xDocNo,xKeyLen)                        
        End If
        
End Function


