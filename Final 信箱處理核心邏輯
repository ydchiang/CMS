        Dim fso, f2  '(Variant 型態) '2021 Fix
        Set fso = CreateObject("Scripting.FileSystemObject")
        
        Set sourceRT = SourceDoc.GetFirstItem(SourceField)
        Set TargetRT = TargetDoc.GetFirstItem(TargetField)
        TempDir =  "E:\APTemp\"
        If Not (sourceRT Is Nothing ) Then
                If Not ( Isempty(sourceRT.EmbeddedObjects) ) Then
                        For i=0 To  Ubound(sourceRT.EmbeddedObjects)
                                filename = sourceRT.EmbeddedObjects(i).Source
