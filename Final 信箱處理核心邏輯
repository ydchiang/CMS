Sub ProcessAttachment1(doc As NotesDocument,tdoc As NotesDocument)
        On Error Goto err_handle         
        '判斷是否有新插入之合約檔案
        Dim contractObjectCount As Integer
        
        Set sourceObject = tdoc.GetFirstItem("Body")        
        
        contractObjectCount = 0
        If Not ( sourceObject Is Nothing ) Then
                If Not ( Isempty(sourceObject.EmbeddedObjects) ) Then
                        Forall contract In sourceObject.EmbeddedObjects
                                contractObjectCount = contractObjectCount + 1
                        End Forall                                        
                End If                                        
        End If
        
        Select Case contractObjectCount
        Case 0 : '沒有新插入之合約檔案
                Call CreateNewContract1(doc,tdoc,0 , sourceObject , 1) '201911 for 取消判斷附件
        Case Else : Call CreateNewContract1(doc,tdoc,1 , sourceObject , 1) '有新插入合約檔案
        End Select
        
        Call doc.Save(True , True)
        Exit Sub        
        
